{
  "name": "video-bg-remover",
  "version": "1.0.0",
  "description": "Remove video backgrounds using AI — desktop app for macOS and Windows",
  "main": "./out/main/index.js",
  "scripts": {
    "predev": "cp src/main/worker.js out/main/worker.js 2>/dev/null || true",
    "dev": "electron-vite dev",
    "build": "electron-vite build && cp src/main/worker.js out/main/worker.js",
    "package:mac": "npm run build && electron-builder --mac",
    "package:win": "npm run build && electron-builder --win",
    "package": "npm run build && electron-builder --mac --win"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "fluent-ffmpeg": "^2.1.3",
    "onnxruntime-node": "^1.24.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.8"
  }
}
